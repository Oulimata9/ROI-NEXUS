# Copy to .env.backend and update the values before running
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=roi_nexus
DATABASE_HOST=db
DATABASE_PORT=5432   # container port stays 5432
# SQLAlchemy style connection string for docker-compose internal network
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/roi_nexus
# when connecting from host (outside docker) use port 5433
SECRET_KEY=change_me
